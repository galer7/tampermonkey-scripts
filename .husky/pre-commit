#!/bin/sh

# Check that @version was bumped in any changed (non-deleted) src/ scripts
for file in $(git diff --cached --diff-filter=d --name-only -- 'src/*.ts'); do
  old_version=$(git show HEAD:"$file" 2>/dev/null | sed -n 's/.*@version[[:space:]]*\([^ ]*\).*/\1/p')
  new_version=$(sed -n 's/.*@version[[:space:]]*\([^ ]*\).*/\1/p' "$file" 2>/dev/null)
  if [ -n "$old_version" ] && [ "$old_version" = "$new_version" ]; then
    echo "ERROR: @version not bumped in $file (still $old_version)"
    exit 1
  fi
done

# Check for private terms in staged files
if [ -f .secrets ]; then
  terms=$(grep -v '^#' .secrets | grep -v '^$' | tr '\n' '|' | sed 's/|$//')
  if [ -n "$terms" ]; then
    matches=$(git diff --cached --diff-filter=d -U0 -- ':!.secrets' ':!.gitignore' | grep -iE "^\+" | grep -iE "$terms" || true)
    if [ -n "$matches" ]; then
      echo "ERROR: Private terms found in staged changes:"
      echo "$matches"
      exit 1
    fi
    # Also check commit message won't be checked here — git-filter handles that
  fi
fi

# Build and stage dist/
pnpm build
git add dist/
